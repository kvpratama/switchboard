# .env.example — copy to .env and fill in

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram user IDs that are allowed to use the bot.
# Find your ID by messaging @userinfobot on Telegram.
ALLOWED_TELEGRAM_USER_IDS=

# --- LLM (provider-agnostic via init_chat_model) ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
# Optional: override base URL (Ollama, Azure proxy, etc.)
# LLM_PROVIDER_BASE_URL=

# --- Google Calendar ---
GOOGLE_OAUTH_CLIENT_SECRETS_PATH=./credentials.json
GOOGLE_OAUTH_TOKEN_PATH=./data/token.json

# --- Persistence ---
CHECKPOINT_DB_PATH=./data/checkpoints.sqlite
# Maximum number of messages to keep in conversation history (default: 50)
# MAX_CONVERSATION_MESSAGES=50

# --- Time handling (optional) ---
# If omitted, Switchboard fetches the timezone from your Google Calendar settings.
# Fallback order: this value → Calendar API → system local time.
# DEFAULT_TIMEZONE=Asia/Tokyo

# --- Logging ---
LOG_LEVEL=INFO

# --- LangSmith (optional, opt-in tracing) ---
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=switchboard
